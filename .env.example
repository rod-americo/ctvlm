# Copy to .env and fill in. docker-compose reads .env automatically.
#
# Required for the first-launch weight download:
#   1. Sign in at https://huggingface.co
#   2. Accept the model license at:
#        https://huggingface.co/stanfordmimi/Merlin        (MIT)
#        https://huggingface.co/YalaLab/Pillar0-AbdomenCT  (permissive)
#   3. Create a token at https://huggingface.co/settings/tokens (read scope is enough)
#   4. Paste it here:
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional — override default operating points / paths. Defaults work for the
# bundled probe + docker-compose layout.

# Worker / inference behavior
# CTVLM_MAX_FINDINGS=12

# Broker integration for deploy/example_worker.py (replace with your real broker)
# CTVLM_REDIS_URL=redis://broker:6379/0
# CTVLM_BROKER_QUEUE=ctvlm.jobs

# Logging
# LOG_LEVEL=INFO
